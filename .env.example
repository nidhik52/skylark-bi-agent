# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Monday.com API token (from: Account → Developers → My Access Tokens)
MONDAY_API_KEY=your_monday_api_token_here

# Groq API key - free at https://console.groq.com -> API Keys
GROQ_API_KEY=your_groq_api_key_here

# Monday.com board IDs (printed by import_boards.py after running it)
DEALS_BOARD_ID=your_deals_board_id_here
WORK_ORDERS_BOARD_ID=your_work_orders_board_id_here
